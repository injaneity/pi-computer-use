{
  "name": "pi-computer-use",
  "version": "0.1.0",
  "description": "Codex-style computer-use tools for Pi on macOS.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "computer-use",
    "macos",
    "screenshot",
    "automation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/injaneity/pi-computer-use.git"
  },
  "bugs": {
    "url": "https://github.com/injaneity/pi-computer-use/issues"
  },
  "homepage": "https://github.com/injaneity/pi-computer-use#readme",
  "engines": {
    "node": ">=20.6.0"
  },
  "files": [
    "extensions",
    "skills",
    "src",
    "scripts/build-native.mjs",
    "scripts/setup-helper.mjs",
    "native/macos/bridge.swift",
    "prebuilt/macos",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "postinstall": "node scripts/setup-helper.mjs --postinstall",
    "build:native": "node scripts/build-native.mjs"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  }
}
