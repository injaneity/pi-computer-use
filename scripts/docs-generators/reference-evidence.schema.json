{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source-owned reference evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "repositoryUrl", "pages"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "repositoryUrl": { "type": "string", "format": "uri" },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "outputPath", "title", "description", "sourcePath", "requiredSymbols"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "outputPath": { "type": "string", "pattern": "^docs/content/docs/reference/.+\\.mdx$" },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "sourcePath": { "type": "string", "minLength": 1 },
          "requiredSymbols": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "requiredCitations": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
